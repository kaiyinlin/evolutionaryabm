---
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<h2><a href="/">evolutionary<span>ABM</span></a></h2>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
			<HeaderLink href="/people">People</HeaderLink>
			<HeaderLink href="/projects">Projects</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
		</div>
	</nav>
</header>

<style>
	header {
		margin: 0;
		padding: 0 1.5em;
		background: white;
		box-shadow: 0 1px 0 rgba(0,0,0,0.08);
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}
	h2 a {
		text-decoration: none;
		color: #111;
		font-weight: 700;
		letter-spacing: -0.3px;
	}
	h2 a span {
		color: #1d9e75;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		height: 56px;
	}
	nav a {
		padding: 0.5em 0.6em;
		color: #555;
		border-bottom: 3px solid transparent;
		text-decoration: none;
		font-size: 0.9rem;
	}
	nav a.active {
		color: #111;
		border-bottom-color: #1d9e75;
	}
	nav a:hover {
		color: #111;
	}
	@media (max-width: 720px) {
		.internal-links {
			display: flex;
			gap: 0;
		}
		nav a {
			padding: 0.5em 0.4em;
			font-size: 0.82rem;
		}
	}
</style>
