---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---
<!doctype html>
<html lang="en">
  <head>
    <BaseHead title="Live Longer" description="Modeling aging and longevity as emergent properties." />
    <style>
      main { max-width: 860px; margin: 0 auto; padding: 2rem 1.5rem; }
      .back { font-size: 13px; color: #888; text-decoration: none; display: inline-flex; align-items: center; gap: 5px; margin-bottom: 1.5rem; }
      .back:hover { color: #111; }
      .proj-tag { font-size: 10px; font-weight: 600; padding: 3px 9px; border-radius: 20px; display: inline-block; margin-bottom: 0.75rem; text-transform: uppercase; background: #eeedfe; color: #3c3489; }
      h1 { font-size: 1.7rem; font-weight: 700; color: #111; margin-bottom: 0.75rem; line-height: 1.3; }
      .lead { font-size: 1rem; color: #555; line-height: 1.75; max-width: 620px; margin-bottom: 2rem; padding-bottom: 2rem; border-bottom: 1px solid #eee; }
      .section { margin-bottom: 2rem; }
      .section h2 { font-size: 0.95rem; font-weight: 600; color: #111; margin-bottom: 0.6rem; }
      .section p { font-size: 0.9rem; color: #555; line-height: 1.75; }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <a href="/projects" class="back">← Back to projects</a>
      <span class="proj-tag">Systems biology</span>
      <h1>Live Longer</h1>
      <p class="lead">Modeling aging and longevity as emergent properties of cellular and molecular interaction networks, informed by systems biology and longevity science research.</p>
      <div class="section">
        <h2>Research questions</h2>
        <p>Can lifespan be extended by modifying interaction rules rather than genes? What cellular network structures are associated with slower aging phenotypes?</p>
      </div>
      <div class="section">
        <h2>Methods</h2>
        <p>Agent-based cellular automata with interaction rules derived from empirical aging datasets. Sensitivity analysis on key longevity parameters.</p>
      </div>
      <div class="section">
        <h2>Status</h2>
        <p>Active — working paper in progress.</p>
      </div>
    </main>
    <Footer />
  </body>
</html>
