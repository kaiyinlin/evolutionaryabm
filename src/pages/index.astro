---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---
<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <style>
      .hero {
        padding: 4rem 0 2.5rem;
        border-bottom: 1px solid #e8e8e8;
        margin-bottom: 3rem;
      }
      .hero-tag {
        font-size: 11px;
        font-weight: 600;
        color: #0f6e56;
        background: #e1f5ee;
        padding: 4px 12px;
        border-radius: 20px;
        display: inline-block;
        margin-bottom: 1.25rem;
        letter-spacing: 0.8px;
        text-transform: uppercase;
      }
      .hero h1 {
        font-size: 2.8rem;
        font-weight: 600;
        line-height: 1.25;
        color: #111;
        margin-bottom: 1rem;
        letter-spacing: -0.5px;
      }
      .hero p {
        font-size: 1.15rem;
        color: #555;
        line-height: 1.75;
        max-width: 580px;
        margin-bottom: 2rem;
      }
      .hero-stats {
        display: flex;
        gap: 2.5rem;
      }
      .stat-num {
        font-size: 1.6rem;
        font-weight: 700;
        color: #111;
      }
      .stat-label {
        font-size: 0.75rem;
        color: #888;
        margin-top: 2px;
      }
      .section-header {
        margin-bottom: 1.5rem;
      }
      .section-header h2 {
        font-size: 1.2rem;
        font-weight: 600;
        color: #111;
      }
      .section-header p {
        font-size: 0.85rem;
        color: #888;
        margin-top: 4px;
      }
      .projects-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: 1rem;
        margin-bottom: 4rem;
      }
      .proj-card {
        border: 1px solid #eee;
        border-radius: 12px;
        padding: 1.25rem;
        text-decoration: none;
        display: block;
        transition: border-color 0.15s, box-shadow 0.15s;
        background: #fff;
      }
      .proj-card:hover {
        border-color: #ccc;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
      }
      .proj-tag {
        font-size: 10px;
        font-weight: 600;
        padding: 3px 9px;
        border-radius: 20px;
        display: inline-block;
        margin-bottom: 0.75rem;
        letter-spacing: 0.3px;
        text-transform: uppercase;
      }
      .tag-teal { background: #e1f5ee; color: #0f6e56; }
      .tag-purple { background: #eeedfe; color: #3c3489; }
      .tag-blue { background: #e6f1fb; color: #0c447c; }
      .tag-amber { background: #faeeda; color: #633806; }
      .tag-coral { background: #faece7; color: #712b13; }
      .proj-card h3 {
        font-size: 1rem;
        font-weight: 600;
        color: #111;
        margin-bottom: 0.5rem;
        line-height: 1.4;
      }
      .proj-card p {
        font-size: 0.9rem;
        color: #666;
        line-height: 1.6;
        margin: 0;
      }
      .proj-card-footer {
        margin-top: 1rem;
        padding-top: 0.75rem;
        border-top: 1px solid #f0f0f0;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }
      .proj-status {
        font-size: 11px;
        color: #888;
        display: flex;
        align-items: center;
        gap: 5px;
      }
      .proj-status::before {
        content: '';
        display: inline-block;
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: #1d9e75;
      }
      .proj-arrow { font-size: 13px; color: #aaa; }
      .sub-count {
        font-size: 10px;
        color: #aaa;
        margin-bottom: 4px;
      }
    </style>
  </head>
  <body>
    <Header />
    <main style="max-width: 860px; margin: 0 auto; padding: 0 0.75rem;">

      <div class="hero">
        <div class="hero-tag">Research Group</div>
        <h1>Modeling complex systems<br />from cells to societies</h1>
        <p>We use agent-based modeling and evolutionary simulation to study cooperation, ecology, longevity, and political behavior across scales.</p>
        <div class="hero-stats">
          <div>
            <div class="stat-num">7</div>
            <div class="stat-label">Active projects</div>
          </div>
          <div>
            <div class="stat-num">3</div>
            <div class="stat-label">Lab members</div>
          </div>
        </div>
      </div>

      <div class="section-header">
        <h2>Research areas</h2>
        <p>Click any project to explore</p>
      </div>

      <div class="projects-grid">

        <a href="/projects/evolution-cooperation" class="proj-card">
          <span class="proj-tag tag-teal">Biology · Game theory</span>
          <div class="sub-count">3 projects</div>
          <h3>Evolution of cooperation and fairness</h3>
          <p>How cooperative behaviors evolve when selfish strategies seem to dominate.</p>
          <div class="proj-card-footer">
            <span class="proj-status">Active</span>
            <span class="proj-arrow">→</span>
          </div>
        </a>

        <a href="/projects/live-longer" class="proj-card">
          <span class="proj-tag tag-purple">Systems biology</span>
          <h3>Live Longer</h3>
          <p>Modeling aging and longevity as emergent properties of cellular interaction networks.</p>
          <div class="proj-card-footer">
            <span class="proj-status">Active</span>
            <span class="proj-arrow">→</span>
          </div>
        </a>

        <a href="/projects/cells" class="proj-card">
          <span class="proj-tag tag-blue">Computational biology</span>
          <h3>Cells</h3>
          <p>How tissue-level patterns emerge from cell-level rules of division and signaling.</p>
          <div class="proj-card-footer">
            <span class="proj-status">Active</span>
            <span class="proj-arrow">→</span>
          </div>
        </a>

        <a href="/projects/reset" class="proj-card">
          <span class="proj-tag tag-amber">Ecology</span>
          <h3>RESET — Ecology and conservation</h3>
          <p>Ecosystem resilience, tipping points, and conservation using evolutionary ABM.</p>
          <div class="proj-card-footer">
            <span class="proj-status">Active</span>
            <span class="proj-arrow">→</span>
          </div>
        </a>

        <a href="/projects/security" class="proj-card">
          <span class="proj-tag tag-coral">Political science</span>
          <h3>Security cooperation and burden sharing</h3>
          <p>Modeling alliance dynamics and why some members consistently under-contribute.</p>
          <div class="proj-card-footer">
            <span class="proj-status">Active</span>
            <span class="proj-arrow">→</span>
          </div>
        </a>

      </div>
    </main>
    <Footer />
  </body>
</html>
